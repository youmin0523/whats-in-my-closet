# =============================================================================
# What's in my closet — environment variables
# Copy this file to `.env` (repo root, used by DB scripts) AND copy the
# app-relevant vars into `apps/web/.env.local` (used by Next.js at runtime).
# Never commit real secrets. See HANDOFF.md.
# =============================================================================

# --- Database (PostgreSQL 16 + pgvector) -------------------------------------
# Local dev: create the DB first, then set the password you chose at install.
#   createdb closet_dev   (or via pgAdmin)
# Production (Supabase): use the POOLED string (port 6543) for the app, and the
# DIRECT string (port 5432) only for migrations. See DEPLOY.md.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/closet_dev"
# Prod tuning (leave blank locally):
DATABASE_PREPARE=""        # "false" when using a transaction pooler (Supabase :6543 / PgBouncer)
DATABASE_POOL_MAX=""       # serverless: "1" recommended; blank = 10
DATABASE_IDLE_TIMEOUT=""   # seconds; blank = 20

# --- Auth.js (NextAuth v5) ---------------------------------------------------
# Generate a secret:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""
# Production (Vercel): set to "true" so Auth.js trusts the deployment host.
AUTH_TRUST_HOST=""
# Korea-first social login (register apps at developers.kakao.com / Naver / Google)
AUTH_KAKAO_ID=""
AUTH_KAKAO_SECRET=""
AUTH_NAVER_ID=""
AUTH_NAVER_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Dev-only: enable a passwordless "dev login" so you can sign in without OAuth keys.
# MUST be unset/false in production.
AUTH_DEV_LOGIN="true"

# --- Image storage (Cloudinary: storage + CDN + AI background removal) -------
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# --- AI text/vision LLM ------------------------------------------------------
# Powers auto-tagging, multi-item detection, tag OCR, recommendations, stylist Q&A.
# Set EITHER OpenAI OR Anthropic (OpenAI is preferred when both are present).
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"            # optional (cheap + vision)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"   # optional override
# Marqo-FashionSigLIP image embeddings (MVP via Replicate; later self-host)
REPLICATE_API_TOKEN=""
REPLICATE_FASHION_EMBED_VERSION=""    # Replicate model version hash for FashionSigLIP
# Virtual try-on (Phase 4)
FASHN_API_KEY=""

# --- Weather (Phase 3) -------------------------------------------------------
# 기상청 단기예보 service key from data.go.kr (URL-encoded)
KMA_SERVICE_KEY=""
# Optional: 에어코리아 미세먼지
AIRKOREA_SERVICE_KEY=""

# --- Payments (freemium subscriptions, KRW) ---------------------------------
# Set EITHER PortOne(포트원) OR Toss. Without these, "구독" activates immediately
# in dev (settings page works); with a key, it returns a checkout URL.
PORTONE_API_SECRET=""
TOSS_SECRET_KEY=""
# Optional: hosted checkout page to redirect to (else an in-app /settings/confirm stub)
BILLING_CHECKOUT_URL=""

# --- Product catalog enrichment (scan-tag → 실제 상품 매칭) -------------------
# Naver 검색 API (openapi.naver.com) — without keys, tag-scan still works (no matches)
NAVER_SEARCH_CLIENT_ID=""
NAVER_SEARCH_CLIENT_SECRET=""
